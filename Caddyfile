{
	# Railway terminates TLS at the edge
	auto_https off
}

:{$PORT:8080} {
	encode gzip

	# SPA (Vite base `/app/`) — strip prefix so static server sees /assets, /
	handle_path /app* {
		reverse_proxy {$WEB_UPSTREAM:http://web.railway.internal:8080}
	}

	handle /api* {
		reverse_proxy {$API_UPSTREAM:http://api.railway.internal:3001}
	}

	handle /.well-known* {
		reverse_proxy {$API_UPSTREAM:http://api.railway.internal:3001}
	}

	handle /health {
		reverse_proxy {$API_UPSTREAM:http://api.railway.internal:3001}
	}

	handle {
		reverse_proxy {$MARKETING_UPSTREAM:http://marketing.railway.internal:8080}
	}
}
