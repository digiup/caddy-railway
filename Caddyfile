{
    # Railway handles TLS termination at the edge
    auto_https off
}

:{$PORT:8080} {
    # 1. Route specific path to another app's dist folder
    handle_path /app/* {
        reverse_proxy http://web.railway.internal
    }

    # 2. Route API or main traffic to an internal server URL
    handle /api/* {
        reverse_proxy http://api.railway.internal
    }

    # 3. Default fallback for the primary app dist folder
    # handle {
    #     reverse_proxy http://marketing.railway.internal
    # }
}
